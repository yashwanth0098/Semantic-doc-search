from openai import AzureOpenAI
from dotenv import load_dotenv
import os
from tqdm import tqdm
from HR_project_logging.project_logging import get_logger

logger = get_logger(__name__)

load_dotenv()

client = AzureOpenAI(
    api_key=os.getenv("AZURE_OPENAI_API_KEY"),
    api_version=os.getenv("AZURE_OPENAI_API_VERSION"),
    azure_endpoint=os.getenv("AZURE_OPENAI_ENDPOINT")
)

DEPLOYMENT_NAME = os.getenv("AZURE_OPENAI_EMBEDDING_DEPLOYMENT")


def generate_embeddings(chunks, batch_size=20):
    embeddings = []

    try:
        for i in tqdm(range(0, len(chunks), batch_size)):
            batch = chunks[i:i + batch_size]

            texts = [c["text"] for c in batch]

            try:
                response = client.embeddings.create(
                    model=DEPLOYMENT_NAME,
                    input=texts
                )

                for j, emb in enumerate(response.data):
                    embeddings.append({
                        "chunk_id": batch[j]["chunk_id"],
                        "source_file": batch[j]["source_file"],
                        "text": batch[j]["text"],
                        "embedding": emb.embedding
                    })

            except Exception:
                logger.error(f"Embedding batch failed at index {i}", exc_info=True)

        logger.info(f"Generated embeddings for {len(embeddings)} chunks.")

    except Exception:
        logger.critical("Embedding generation failed.", exc_info=True)
        raise

    return embeddings





def evaluate_embedding_drift(old_embeddings, new_embeddings):
    thresholds = {
        "centroid": 0.5,
        "cosine": 0.90,
        "l2_mean": 0.1,
        "l2_std": 0.1
    }

    results = {}

    c_shift = centroid_shift(old_embeddings, new_embeddings)
    cos_sim = average_cosine_similarity(old_embeddings, new_embeddings)
    l2_stats = l2_drift(old_embeddings, new_embeddings)

    results["centroid_shift"] = c_shift
    results["avg_cosine_similarity"] = cos_sim
    results.update(l2_stats)

    flags = []

    if c_shift > thresholds["centroid"]:
        flags.append("centroid")

    if cos_sim < thresholds["cosine"]:
        flags.append("cosine")

    if l2_stats["mean_shift"] > thresholds["l2_mean"]:
        flags.append("l2_mean")

    if l2_stats["std_shift"] > thresholds["l2_std"]:
        flags.append("l2_std")

    return {
        "drift_detected": len(flags) > 0,
        "flags": flags,
        "metrics": results
    }


