from evaluation.hr.metrics import (
    faithfulness,
    hallucination_rate,
    answer_relevance,
    context_relevance,
    confidence_score
)


class HREvaluator:

    def evaluate(self, question, answer, context):

        f = faithfulness(answer, context)
        h = hallucination_rate(answer, context)
        ar = answer_relevance(question, answer)
        cr = context_relevance(question, context)
        cs = confidence_score(h)

        return {
            "faithfulness": f,
            "hallucination_rate": h,
            "answer_relevance": ar,
            "context_relevance": cr,
            "confidence_score": cs
        }



