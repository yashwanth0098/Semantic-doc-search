def extract_token_usage(metadata):

    if "usage" in metadata:
        return metadata["usage"]

    # fallback estimation
    text = metadata.get("response", "")
    tokens = int(len(text.split()) * 1.3)

    return {
        "prompt_tokens": None,
        "completion_tokens": tokens,
        "total_tokens": tokens
    }




