kdef __init__(self, base_url, access_token, headers=None):
        self.ws_url = build_ws_url(base_url, access_token)
        self.headers = headers or []

    def query(self, question: str):

        session_id = f"eval-{int(time.time() * 1000)}"

        payload = {
            "client": "Edge",
            "query": question,
            "email": "",
            "session_id": session_id,
            "local_time": datetime.now().isoformat(),
            "tone": "formal",
            "access_token": None
        }

        ws = websocket.WebSocket()

        ws.connect(
            self.ws_url,
            sslopt={
                "cert_reqs": ssl.CERT_NONE,
                "check_hostname": False
            },
            header=self.headers
        )

        final_answer = ""
        chunks = []
        metadata = {}

        ws.send(json.dumps(payload))

        while True:
            message = ws.recv()

            try:
                data = json.loads(message)
            except:
                continue

            if "chunk" in data:
                chunks.append(data["chunk"])
                final_answer += data["chunk"]

            if "usage" in data:
                metadata["usage"] = data["usage"]

            if data.get("status") == "completed":
                final_answer = data.get("response", final_answer)
                metadata.update(data)
                break

        ws.close()

        return {
            "answer": final_answer,
            "chunks": chunks,
            "metadata": metadata
        }



