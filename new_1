from pathlib import Path
from typing import Dict
from config.path import PROCESSED_DIR
from HR_project_logging.project_logging import get_logger

logger = get_logger(__name__)

def load_processed_documents() -> Dict[str, str]:
    docs = {}

    try:
        txt_files = list(PROCESSED_DIR.glob("*.txt"))
        json_files = list(PROCESSED_DIR.glob("*.json"))

        if json_files:
            logger.info(f"Found {len(json_files)} JSON files (metadata) in processed folder.")

        if not txt_files:
            logger.warning("No .txt files found in processed folder.")
            return docs

        for file in txt_files:
            try:
                with open(file, "r", encoding="utf-8") as f:
                    docs[file.name] = f.read()

            except Exception as file_error:
                logger.error(f"Failed to load file: {file.name}", exc_info=True)

        logger.info(f"Loaded {len(docs)} processed text documents.")

    except Exception as e:
        logger.error("Error loading processed documents.", exc_info=True)
        raise e

    return docs









from typing import Dict, List
from HR_project_logging.project_logging import get_logger

logger = get_logger(__name__)


def chunk_documents(
    documents: Dict[str, str],
    chunk_size: int = 500,
    chunk_overlap: int = 50
) -> List[Dict]:
    """
    Split documents into chunks with overlap.

    Args:
        documents: Dict[file_name, text]
        chunk_size: max characters per chunk
        chunk_overlap: overlap between chunks

    Returns:
        List of chunk dictionaries
    """

    chunks = []

    try:
        for file_name, text in documents.items():
            try:
                if not text.strip():
                    logger.warning(f"Skipping empty document: {file_name}")
                    continue

                start = 0
                chunk_id = 0
                text_length = len(text)

                while start < text_length:
                    end = start + chunk_size

                    chunk_text = text[start:end]

                    chunks.append({
                        "chunk_id": f"{file_name}_chunk_{chunk_id}",
                        "source_file": file_name,
                        "text": chunk_text.strip()
                    })

                    chunk_id += 1
                    start += (chunk_size - chunk_overlap)

                logger.info(f"Chunked {file_name} into {chunk_id} chunks.")

            except Exception as file_error:
                logger.error(f"Error processing file: {file_name}", exc_info=True)

        logger.info(f"Total chunks created: {len(chunks)}")

    except Exception as e:
        logger.critical("Chunking failed at document level.", exc_info=True)
        raise e

    return chunks
