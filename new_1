import json
from config.settings import Settings
from orchestrator_at_evaluation_side_to_production_side.orchestrator import RAGOrchestrator
from evaluation.hr.evaluator import HREvaluator
from utils.token_utils import extract_token_usage


class HRPipeline:

    def __init__(self):
        self.orchestrator = RAGOrchestrator(
            Settings.WS_BASE_URL,
            Settings.ACCESS_TOKEN,
            Settings.WS_HEADERS
        )
        self.evaluator = HREvaluator()

    def run(self):

        # Load questions
        with open(Settings.HR_INPUT_PATH, "r") as f:
            questions = json.load(f)

        results = []

        # Batch processing (simple loop)
        for item in questions:

            question = item["question"]
            print(f"\nProcessing: {question}")

            # 1. Call RAG
            response = self.orchestrator.query(question)

            answer = response["answer"]
            context = " ".join(response["chunks"])
            metadata = response["metadata"]

            # 2. Evaluate
            metrics = self.evaluator.evaluate(
                question,
                answer,
                context
            )

            # 3. Token usage
            tokens = extract_token_usage(metadata)

            result = {
                "question": question,
                "answer": answer,
                "tokens": tokens,
                "metrics": metrics
            }

            results.append(result)

        # Save output
        with open(Settings.HR_OUTPUT_PATH, "w") as f:
            json.dump(results, f, indent=4)

        print("\n✅ HR Evaluation Completed")




