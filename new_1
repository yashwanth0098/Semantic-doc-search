def precision_at_k(retrieved_chunks, relevant_chunks, k=3):
    retrieved_k = retrieved_chunks[:k]

    if not retrieved_k:
        return 0.0

    relevant_count = sum(1 for chunk in retrieved_k if chunk in relevant_chunks)

    return relevant_count / k


def recall_at_k(retrieved_chunks, relevant_chunks, k=3):
    retrieved_k = retrieved_chunks[:k]

    if not relevant_chunks:
        return 0.0

    relevant_count = sum(1 for chunk in retrieved_k if chunk in relevant_chunks)

    return relevant_count / len(relevant_chunks)


def mean_reciprocal_rank(retrieved_chunks, relevant_chunks):
    for idx, chunk in enumerate(retrieved_chunks):
        if chunk in relevant_chunks:
            return 1 / (idx + 1)
    return 0.0


