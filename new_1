from difflib import SequenceMatcher


def similarity(a, b):
    return SequenceMatcher(None, a, b).ratio()


def faithfulness(answer, context):
    if not context:
        return 0.0
    return similarity(answer, context)


def hallucination_rate(answer, context):
    if not context:
        return 1.0
    return 1 - similarity(answer, context)


def answer_relevance(question, answer):
    return similarity(question, answer)


def context_relevance(question, context):
    return similarity(question, context)


def confidence_score(hallucination):
    return max(0, 1 - hallucination)



